# ArthaChakra — Step 1 + Step 2: core/users/Mongo schema + auth/kite_oauth/login
# Copy this file to .env and adjust if needed.
# Works with NO MongoDB installed — falls back to in-memory mock automatically.

# ── MongoDB ──────────────────────────────────────────────────────────────
# Brand new database, separate from POC1's "nse_trading" / "trading_agent".
ARTHACHAKRA_MONGO_URI=mongodb://localhost:27017
ARTHACHAKRA_DB_NAME=arthachakra

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs/

# ── Kite Connect ─────────────────────────────────────────────────────────
# No platform-level API key needed here. Each user enters their OWN
# personal Kite Connect api_key/api_secret directly in the app's
# "Add a Kite account" form — it's saved as part of their profile,
# never shared with other users. Register a personal app once at
# https://developers.kite.trade if you don't have one yet.
# ── Dhan HQ — shared platform key for option chain Greeks ────────────────
# NOT user-specific. One key gives access to the public option chain
# endpoint for all NSE F&O Greeks (delta, IV, etc.).
# Get yours at https://dhanhq.co/docs/latest/option-chain/
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=