# ArthaChakra — Step 1: core/ + users/ + Mongo schema
# Copy this file to .env and adjust if needed.
# Works with NO MongoDB installed — falls back to in-memory mock automatically.

# ── MongoDB ──────────────────────────────────────────────────────────────
# Brand new database, separate from POC1's "nse_trading" / "trading_agent".
ARTHACHAKRA_MONGO_URI=mongodb://localhost:27017
ARTHACHAKRA_DB_NAME=arthachakra

# ── Logging ──────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_DIR=logs/
